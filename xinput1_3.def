; xinput1_3.dll export definitions.
; Ordinals match Microsoft's xinput1_3.dll.

LIBRARY xinput1_3

EXPORTS
    XInputGetState                  @2
    XInputSetState                  @3
    XInputGetCapabilities           @4
    XInputEnable                    @5
    XInputGetDSoundAudioDeviceGuids @6
    XInputGetBatteryInformation     @7
    XInputGetKeystroke              @8
    XInputGetStateEx                @100  NONAME
