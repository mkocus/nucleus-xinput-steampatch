; xinput1_4.dll export definitions.
; Ordinals match Microsoft's xinput1_4.dll.
; Use this instead of xinput1_3.def for games that load xinput1_4.dll.

LIBRARY xinput1_4

EXPORTS
    XInputGetState                  @2
    XInputSetState                  @3
    XInputGetCapabilities           @4
    XInputEnable                    @5
    XInputGetDSoundAudioDeviceGuids @6
    XInputGetBatteryInformation     @7
    XInputGetKeystroke              @8
    XInputGetAudioDeviceIds         @10
    XInputGetStateEx                @100  NONAME
